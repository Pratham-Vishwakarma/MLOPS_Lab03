pipeline{
    agent any

    stages{
        stage('Checkout SCM'){
            steps{
                checkout scm
            }
        }
        stage('Install Dependencies'){
            steps{
                pip install -r requirements.txt
            }
        }

        stage('Train Model'){
            steps{
                python sr/train.py
            }
        }

        stage('Test Model'){
            steps{
                python src/test.py
            }
        }
    }

}
